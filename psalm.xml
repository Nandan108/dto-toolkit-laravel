<?xml version="1.0"?>
<psalm errorLevel="1" resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config" xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd" findUnusedBaselineEntry="true" findUnusedCode="true" phpVersion="8.1">
    <projectFiles>
        <directory name="src" />
        <directory name="tests" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <ArgumentTypeCoercion><errorLevel type="suppress"><directory name="tests" /></errorLevel></ArgumentTypeCoercion>
        <InvalidArgument><errorLevel type="suppress"><directory name="tests" /></errorLevel></InvalidArgument>
        <MixedAssignment><errorLevel type="suppress"><directory name="tests" /></errorLevel></MixedAssignment>
        <MixedMethodCall><errorLevel type="suppress"><directory name="tests" /></errorLevel></MixedMethodCall>
        <MixedArgumentTypeCoercion><errorLevel type="suppress"><directory name="tests" /></errorLevel></MixedArgumentTypeCoercion>
        <PossiblyUnusedMethod><errorLevel type="suppress"><directory name="tests" /></errorLevel></PossiblyUnusedMethod>
        <PossiblyUnusedProperty><errorLevel type="suppress"><directory name="tests" /></errorLevel></PossiblyUnusedProperty>
        <PropertyNotSetInConstructor><errorLevel type="suppress"><directory name="tests" /></errorLevel></PropertyNotSetInConstructor>
        <RiskyTruthyFalsyComparison><errorLevel type="suppress"><directory name="tests" /></errorLevel></RiskyTruthyFalsyComparison>
        <UndefinedMagicPropertyAssignment><errorLevel type="suppress"><directory name="tests" /></errorLevel></UndefinedMagicPropertyAssignment>
        <UndefinedMagicPropertyFetch><errorLevel type="suppress"><directory name="tests" /></errorLevel></UndefinedMagicPropertyFetch>
        <UnusedClass><errorLevel type="suppress"><directory name="tests" /></errorLevel></UnusedClass>
    </issueHandlers>
</psalm>
